{
  "name": "pokemon-tcg-pocket-database",
  "version": "2.8.0",
  "description": "Pokemon TCG Pocket complete cards and sets JSON database",
  "files": [
    "dist/*.json",
    "dist/cards/*.json",
    "dist/images/rarities/*"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "scraping": "tsx ./scripts/scraps.ts",
    "download": "tsx ./scripts/download-images.ts",
    "sqliteDB": "tsx ./scripts/convert-to-sqlite.ts"
  },
  "keywords": [
    "pokemon",
    "pokemon tcg",
    "pokemon pocket",
    "Pokemon TCG Pocket",
    "pokemon tcgp",
    "pokemon cards",
    "PTCGP"
  ],
  "author": "flibustier",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flibustier/pokemon-tcg-pocket-database.git"
  },
  "bugs": {
    "url": "https://github.com/flibustier/pokemon-tcg-pocket-database/issues"
  },
  "homepage": "https://github.com/flibustier/pokemon-tcg-pocket-database#readme",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cheerio": "^1.2.0",
    "puppeteer": "^25.3.0",
    "tsx": "^4.23.0",
    "typescript": "latest",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@heyputer/puter.js": "^2.5.4",
    "@invertase/firestore-stripe-payments": "^0.0.8",
    "@tanstack/react-query": "^5.101.2",
    "cors": "^2.8.6",
    "dateformat": "^5.0.3",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1",
    "styled-components": "^6.4.3",
    "web-vitals": "^5.3.0"
  }
}
